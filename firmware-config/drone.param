# ArduPilot parameter file — Raspi WiFi control bridge
#
# Load via Mission Planner / QGroundControl "Load from file", or
# `param load drone.param` in MAVProxy. Review each value against
# your actual FC before writing — this is a starting point, not gospel.
#
# NOTE: parameter lines must be bare `NAME,VALUE` with no trailing inline
# comment — MAVProxy's (and Mission Planner's/QGC's) param-file parser
# rejects lines with anything after the value, hence comments live on
# their own lines above each parameter.

# --- Airframe ---
# FRAME_CLASS: 1 = Quad
FRAME_CLASS,1
# FRAME_TYPE: 1 = X
FRAME_TYPE,1

# --- UART3 (R3/T3) -> Raspi MAVLink2 link ---
# 2026-07-21: moved off UART2 (R2/T2) after finding the FC's R2 pin
# electrically damaged (idles at 2.6V instead of 3.3V) -- see docs/wiring.md.
# SERIAL3_PROTOCOL: 2 = MAVLink2
SERIAL3_PROTOCOL,2
# SERIAL3_BAUD: 57600 baud; raise (e.g. 921 for 921600) later if telemetry
# rate needs it, matching Raspi-side config
SERIAL3_BAUD,57

# --- GCS-loss failsafe: the sole safety net (no backup RC) ---
# FS_GCS_ENABLE: 5 = Land on heartbeat loss from Raspi (acting as GCS).
# NOT 1 (RTL always) or 3 (SmartRTL-or-RTL) -- both need a GPS-derived home
# position, which this airframe cannot produce (no GPS module). Confirmed
# 2026-07-23 by reading the live FC param directly (was previously
# mis-recorded as "3" in bench-test-checklist.md prose -- 5 is correct).
FS_GCS_ENABLE,5
# FS_GCS_TIMEOUT: seconds without heartbeat before failsafe triggers (tune
# down once link is proven reliable; do not go below what bench testing
# shows is safe)
FS_GCS_TIMEOUT,5

# --- Arming without RC receiver present ---
# RC_PROTOCOLS: keep RC protocol autodetect enabled; MAVLink arm/disarm
# command works regardless of RC presence
RC_PROTOCOLS,-1
# ARMING_CHECK: 9650 = bitmask with RC Channels(64), GPS Lock(8), and
# Compass(4) excluded -- confirmed 2026-07-21 these three blocked
# MAVLink-commanded arm with no RC receiver and no GPS/compass module
# present. Remaining checks still active: Barometer(2), INS(16),
# Parameters(32), Board voltage(128), Battery(256), Logging(1024),
# System(8192). Confirmed 2026-07-23 by reading the live FC param
# directly. Do not widen back toward 1 (all) without re-confirming arming
# still works -- this airframe has no RC receiver, GPS, or compass.
ARMING_CHECK,9650
# FS_THR_ENABLE: the RC/throttle failsafe watches for RC receiver signal
# specifically and disarms ("Radio Failsafe") when none is present — this
# is a DIFFERENT failsafe than FS_GCS_ENABLE (MAVLink heartbeat loss, our
# actual safety net). Confirmed 2026-07-21: with the factory default left
# enabled, the FC armed successfully then immediately disarmed itself with
# "Radio Failsafe - Disarming" since no RC receiver will ever be present.
# Must be disabled; FS_GCS_ENABLE remains the sole failsafe for this design.
FS_THR_ENABLE,0

# --- No GPS module on this airframe (confirmed 2026-07-21) ---
# There is no position estimate at all, so: no GPS-fix arm gate (removed
# app-layer and bridge-layer, see CLAUDE.md/mavlink_bridge.py), no
# RTL/Loiter/Auto/PosHold (all need position -- see FS_GCS_ENABLE above and
# the PWA's mode list), geofence below is altitude-only for the same reason.

# --- Geofence: extra safety net for single-link-of-failure design ---
# FENCE_ENABLE: enable geofence subsystem
FENCE_ENABLE,1
# FENCE_TYPE: bitmask: 1=max alt, 2=circle, 4=polygon. 1 = altitude-only --
# circle/polygon need a GPS-derived position this airframe doesn't have.
# Confirmed 2026-07-23 by reading the live FC param directly.
FENCE_TYPE,1
# FENCE_ALT_MAX: meters; set to your legal/site limit
FENCE_ALT_MAX,100
# FENCE_RADIUS: meters; set to your site's safe radius
FENCE_RADIUS,300
# FENCE_ACTION: 1 = RTL-or-Land on breach; falls back to Land since this
# airframe has no GPS/home position (matches FS_GCS_ENABLE=5 behavior)
FENCE_ACTION,1
